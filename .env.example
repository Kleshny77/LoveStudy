# Токен бота от @BotFather в Telegram (в репо оставь заглушку, реальный — только в .env)
BOT_TOKEN=your_bot_token_here

# БД (необязательно). Для Yandex Managed PostgreSQL — строка из консоли.
# DATABASE_URL=postgresql+asyncpg://user:password@c-xxx.rw.mdb.yandexcloud.net:6432/dbname?sslmode=require

# AI-викторины: основной провайдер — Gemini-compatible endpoint
# Пример:
# GEMINI_PROXY_API_KEY=your_provider_key
# GEMINI_PROXY_BASE_URL=https://api.artemox.com/v1
# GEMINI_PROXY_MODEL=gemini-3.1-flash-lite-preview
#
# Резервные провайдеры:
# GEMINI_API_KEY=your_google_gemini_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
# GROQ_API_KEY=your_groq_api_key
#
# Подписка LoveStudy Pro в Telegram Stars
# SUBSCRIPTION_PRICE_STARS=199
#
# Контакт для вопросов по оплате (/paysupport)
# PAY_SUPPORT_CONTACT=@your_support_username
