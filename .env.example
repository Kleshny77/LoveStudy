# Скопируй в .env и заполни значения:
#   cp .env.example .env

# Обязательно: токен от @BotFather (/newbot или /mybots → API Token)
BOT_TOKEN=your_bot_token_here

# Опционально: PostgreSQL (Yandex Managed и т.п.). Один хост-мастер, порт 6432, SSL.
# Спецсимволы в пароле — URL-encode: https://www.urlencoder.org/
# DATABASE_URL=postgresql://user:password@host.mdb.yandexcloud.net:6432/dbname?sslmode=require

# AI-викторины (хотя бы один способ, если нужны тесты по материалам)
# GEMINI_PROXY_API_KEY=
# GEMINI_PROXY_BASE_URL=https://api.artemox.com/v1
# Модель — точное имя из allowlist команды Artemox (в 401 в теле ответа есть список).
# Нет модели gemini-2.0-flash-lite-preview — будет 401 team_model_access_denied.
# Для flash-lite preview из списка: gemini-3.1-flash-lite-preview. Стабильнее: gemini-2.0-flash.
# gemini-2.0-flash-lite иногда режется guardrail'ом (400 Dissalowed model A2).
# GEMINI_PROXY_MODEL=gemini-2.0-flash
#
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=

# Подписка (Stars)
# SUBSCRIPTION_PRICE_STARS=199
# PAY_SUPPORT_CONTACT=@your_support_username

# Аналитика: события в таблицу analytics_events (нужен DATABASE_URL). 0 = выкл.
# ANALYTICS_ENABLED=1
